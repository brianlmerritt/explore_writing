# Copy this file to .env and fill in the keys for the providers you plan to use.
# You only need keys for providers referenced in spec.yaml / rubric.yaml.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Local LLM served via an OpenAI-compatible endpoint
# (Ollama default, llama.cpp server, vLLM, LM Studio, etc.)
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_API_KEY=ollama

# Paths to your prompt and recipe folders.
# Leave blank to use the bundled examples (prompt_examples/ and prompt_recipe_examples/).
PROMPT_FOLDER_PATH=
PROMPT_RECIPE_FOLDER_PATH=

# Path to the folder containing rubric.yaml for review.py.
# Leave blank or set to . to use the project root (default rubric.yaml).
REVIEW_FOLDER_PATH=

# Path to the optional folder containing a reference work for the compare_to_reference rubric criterion.
# Leave blank if not using the compare_to_reference criterion.
STORY_TO_COMPARE_PATH=

# Path to save generated outputs as markdown files.
# explore.py writes one file per sample and stores the filename in generations.tsv.
# Leave blank to use the project default (output_text/).
OUTPUT_TEXT_FOLDER_PATH=
