# Copy this file to .env and fill in the keys for the providers you plan to use.
# You only need keys for providers referenced in spec.yaml / rubric.yaml.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Local LLM served via an OpenAI-compatible endpoint
# (Ollama default, llama.cpp server, vLLM, LM Studio, etc.)
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_API_KEY=ollama
